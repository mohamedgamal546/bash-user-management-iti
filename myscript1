#!/bin/bash

# Check root
if [[ $EUID -ne 0 ]]; then
    echo "Please run as root"
    exit 1
fi

# Message box
msg() {
    whiptail --title "Info" --msgbox "$1" 10 50
}

# Input box
input() {
    whiptail --inputbox "$1" 10 50 3>&1 1>&2 2>&3
}

# ================= USERS =================

add_user() {
    USER=$(input "Enter username:")
    if id "$USER" &>/dev/null; then
        msg "User already exists!"
    else
        useradd "$USER" && msg "User created successfully"
    fi
}

modify_user() {
    USER=$(input "Enter username:")
    NEWNAME=$(input "Enter new username:")
    usermod -l "$NEWNAME" "$USER" && msg "User modified"
}

delete_user() {
    USER=$(input "Enter username:")
    if id "$USER" &>/dev/null; then
        userdel "$USER" && msg "User deleted"
    else
        msg "User not found!"
    fi
}

list_users() {
    USERS=$(cut -d: -f1 /etc/passwd)
    whiptail --title "Users List" --msgbox "$USERS" 20 50
}

disable_user() {
    USER=$(input "Enter username:")
    usermod -L "$USER" && msg "User disabled"
}

enable_user() {
    USER=$(input "Enter username:")
    usermod -U "$USER" && msg "User enabled"
}

change_password() {
    USER=$(input "Enter username:")
    passwd "$USER"
}

# ================= GROUPS =================

add_group() {
    GROUP=$(input "Enter group name:")
    if getent group "$GROUP" > /dev/null; then
        msg "Group already exists!"
    else
        groupadd "$GROUP" && msg "Group created"
    fi
}

modify_group() {
    GROUP=$(input "Enter group name:")
    USER=$(input "Enter username to add to group:")
    usermod -aG "$GROUP" "$USER" && msg "User added to group"
}

delete_group() {
    GROUP=$(input "Enter group name:")
    groupdel "$GROUP" && msg "Group deleted"
}

list_groups() {
    GROUPS=$(cut -d: -f1 /etc/group)
    whiptail --title "Groups List" --msgbox "$GROUPS" 20 50
}

# ================= MAIN MENU =================

while true; do
    CHOICE=$(whiptail --title "User Management System" --menu "Main Menu" 20 60 15 \
    "1" "Add User" \
    "2" "Modify User" \
    "3" "Delete User" \
    "4" "List Users" \
    "5" "Add Group" \
    "6" "Modify Group" \
    "7" "Delete Group" \
    "8" "List Groups" \
    "9" "Disable User" \
    "10" "Enable User" \
    "11" "Change Password" \
    "0" "Exit" 3>&1 1>&2 2>&3)

    case $CHOICE in
        1) add_user ;;
        2) modify_user ;;
        3) delete_user ;;
        4) list_users ;;
        5) add_group ;;
        6) modify_group ;;
        7) delete_group ;;
        8) list_groups ;;
        9) disable_user ;;
        10) enable_user ;;
        11) change_password ;;
        0) exit ;;
        *) msg "Invalid option" ;;
    esac
done
